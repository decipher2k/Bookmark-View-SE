{
  "name": "bookmark-news-viewer",
  "productName": "Bookmark News Viewer",
  "version": "1.0.0",
  "description": "Electron app that turns browser bookmarks into a news-style reader.",
  "main": "src/main/main.js",
  "author": "",
  "license": "MIT",
  "engines": {
    "node": ">=20",
    "npm": ">=10"
  },
  "scripts": {
    "start": "electron-forge start",
    "package": "electron-forge package",
